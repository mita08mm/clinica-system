generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// MÓDULO: USUARIOS Y AUTENTICACIÓN
// ========================================

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  rol       Rol
  nombre    String
  apellido  String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evoluciones Evolucion[]
  recetas     Receta[]

  @@index([email])
  @@map("usuarios")
}

enum Rol {
  ADMIN
  MEDICO
  RECEPCIONISTA
}

// ========================================
// MÓDULO: PACIENTES
// ========================================

model Paciente {
  id              String         @id @default(uuid())
  nombre          String
  apellido        String
  documento       String
  tipoDocumento   TipoDocumento
  fechaNacimiento DateTime
  telefono        String
  email           String?
  direccion       String?
  fotoUrl         String?
  estado          EstadoPaciente @default(ACTIVO)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  historiaClinica HistoriaClinica?
  citas           Cita[]
  cobros          Cobro[]
  recetas         Receta[]
  archivos        Archivo[]

  @@unique([documento, tipoDocumento])
  @@index([nombre, apellido])
  @@index([documento])
  @@index([estado])
  @@map("pacientes")
}

enum TipoDocumento {
  DNI
  PASAPORTE
  OTRO
}

enum EstadoPaciente {
  ACTIVO
  INACTIVO
}

// ========================================
// MÓDULO: HISTORIA CLÍNICA
// ========================================

model HistoriaClinica {
  id                   String   @id @default(uuid())
  pacienteId           String   @unique
  diagnosticoPrincipal String?
  antecedentes         String?
  alergias             String?
  medicacionHabitual   String?
  notasGenerales       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  paciente    Paciente    @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  evoluciones Evolucion[]

  @@index([pacienteId])
  @@map("historias_clinicas")
}

model Evolucion {
  id                String    @id @default(uuid())
  pacienteId        String
  historiaClinicaId String
  usuarioId         String
  fecha             DateTime  @default(now())
  motivoConsulta    String
  diagnostico       String
  tratamiento       String?
  observaciones     String?
  proximaConsulta   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  historiaClinica HistoriaClinica @relation(fields: [historiaClinicaId], references: [id], onDelete: Cascade)
  usuario         Usuario         @relation(fields: [usuarioId], references: [id])
  recetas         Receta[]
  cobros          Cobro[]

  @@index([pacienteId])
  @@index([historiaClinicaId])
  @@index([fecha])
  @@map("evoluciones")
}

// ========================================
// MÓDULO: CITAS
// ========================================

model Cita {
  id         String     @id @default(uuid())
  pacienteId String
  fecha      DateTime
  horaInicio String
  horaFin    String
  motivo     String
  estado     EstadoCita @default(PROGRAMADA)
  notas      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  paciente Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([pacienteId])
  @@index([fecha])
  @@index([estado])
  @@map("citas")
}

enum EstadoCita {
  PROGRAMADA
  CONFIRMADA
  EN_CURSO
  COMPLETADA
  CANCELADA
  NO_ASISTIO
}

// ========================================
// MÓDULO: SERVICIOS Y PRODUCTOS
// ========================================

model Servicio {
  id          String      @id @default(uuid())
  codigo      String      @unique
  nombre      String
  descripcion String?
  precio      Decimal     @db.Decimal(10, 2)
  activo      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  itemsCobro  ItemCobro[]

  @@index([codigo])
  @@index([activo])
  @@map("servicios")
}

model Medicamento {
  id          String        @id @default(uuid())
  codigo      String        @unique
  nombre      String
  descripcion String?
  precio      Decimal       @db.Decimal(10, 2)
  stock       Int           @default(0)
  stockMinimo Int           @default(10)
  activo      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  itemsCobro  ItemCobro[]
  itemsReceta ItemReceta[]

  @@index([codigo])
  @@index([activo])
  @@map("medicamentos")
}

model Insumo {
  id          String        @id @default(uuid())
  codigo      String        @unique
  nombre      String
  descripcion String?
  precio      Decimal       @db.Decimal(10, 2)
  stock       Int           @default(0)
  stockMinimo Int           @default(10)
  activo      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  itemsCobro  ItemCobro[]
  itemsReceta ItemReceta[]

  @@index([codigo])
  @@index([activo])
  @@map("insumos")
}

// ========================================
// MÓDULO: COBROS
// ========================================

model Cobro {
  id          String      @id @default(uuid())
  pacienteId  String
  evolucionId String?
  fecha       DateTime    @default(now())
  subtotal    Decimal     @default(0) @db.Decimal(10, 2)
  descuento   Decimal     @default(0) @db.Decimal(10, 2)
  total       Decimal     @default(0) @db.Decimal(10, 2)
  estado      EstadoCobro @default(PENDIENTE)
  notas       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  paciente  Paciente   @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  evolucion Evolucion? @relation(fields: [evolucionId], references: [id])
  items     ItemCobro[]
  pagos     Pago[]

  @@index([pacienteId])
  @@index([estado])
  @@index([fecha])
  @@map("cobros")
}

model ItemCobro {
  id             String        @id @default(uuid())
  cobroId        String
  tipo           TipoItemCobro
  itemId         String
  nombre         String
  cantidad       Int
  precioUnitario Decimal       @db.Decimal(10, 2)
  subtotal       Decimal       @db.Decimal(10, 2)
  createdAt      DateTime      @default(now())

  cobro       Cobro        @relation(fields: [cobroId], references: [id], onDelete: Cascade)
  servicio    Servicio?    @relation(fields: [itemId], references: [id], map: "ItemCobro_servicio_fkey")
  medicamento Medicamento? @relation(fields: [itemId], references: [id], map: "ItemCobro_medicamento_fkey")
  insumo      Insumo?      @relation(fields: [itemId], references: [id], map: "ItemCobro_insumo_fkey")

  @@index([cobroId])
  @@map("items_cobro")
}

enum TipoItemCobro {
  SERVICIO
  MEDICAMENTO
  INSUMO
}

enum EstadoCobro {
  PENDIENTE
  PARCIAL
  PAGADO
  CANCELADO
}

model Pago {
  id         String     @id @default(uuid())
  cobroId    String
  fecha      DateTime   @default(now())
  monto      Decimal    @db.Decimal(10, 2)
  metodoPago MetodoPago
  referencia String?
  notas      String?
  createdAt  DateTime   @default(now())

  cobro Cobro @relation(fields: [cobroId], references: [id], onDelete: Cascade)

  @@index([cobroId])
  @@index([fecha])
  @@map("pagos")
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  OTRO
}

// ========================================
// MÓDULO: RECETAS
// ========================================

model Receta {
  id           String       @id @default(uuid())
  pacienteId   String
  evolucionId  String?
  usuarioId    String
  fecha        DateTime     @default(now())
  indicaciones String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  paciente     Paciente     @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  evolucion    Evolucion?   @relation(fields: [evolucionId], references: [id])
  usuario      Usuario      @relation(fields: [usuarioId], references: [id])
  items        ItemReceta[]

  @@index([pacienteId])
  @@index([fecha])
  @@map("recetas")
}

model ItemReceta {
  id           String           @id @default(uuid())
  recetaId     String
  tipo         TipoItemReceta
  itemId       String
  nombre       String
  cantidad     Int
  dosis        String?
  frecuencia   String?
  duracion     String?
  estado       EstadoItemReceta @default(PRESCRITO)
  precio       Decimal?         @db.Decimal(10, 2)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  receta       Receta           @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  medicamentoId String?
  insumoId      String?
  medicamento  Medicamento?     @relation(fields: [medicamentoId], references: [id])
  insumo       Insumo?          @relation(fields: [insumoId], references: [id])

  @@index([recetaId])
  @@index([estado])
  @@map("items_receta")
}

enum TipoItemReceta {
  MEDICAMENTO
  INSUMO
}

enum EstadoItemReceta {
  PRESCRITO
  ENTREGADO
}

// ========================================
// MÓDULO: ARCHIVOS
// ========================================

model Archivo {
  id         String      @id @default(uuid())
  pacienteId String
  nombre     String
  tipo       TipoArchivo
  url        String
  tamaño     Int
  mimeType   String
  createdAt  DateTime    @default(now())
  paciente   Paciente    @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([pacienteId])
  @@index([tipo])
  @@map("archivos")
}

enum TipoArchivo {
  ESTUDIO
  IMAGEN
  DOCUMENTO
  OTRO
}
