datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ========================================
// MÓDULO: USUARIOS Y AUTENTICACIÓN
// ========================================

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  rol       Rol
  nombre    String
  apellido  String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tratamientos Tratamiento[]
  protocolos   Protocolo[]

  @@index([email])
  @@map("usuarios")
}

enum Rol {
  ADMIN
  TERAPEUTA // Especialista en medicina estética
  RECEPCIONISTA
}

// ========================================
// MÓDULO: PACIENTES
// ========================================

model Paciente {
  id              String                 @id @default(uuid())
  nombre          String
  apellido        String
  documento       String
  tipoDocumento   TipoDocumentoIdentidad
  fechaNacimiento DateTime
  telefono        String
  email           String?
  direccion       String?
  sexo            String?

  // Campos específicos de medicina estética
  objetivoEstetico   String? // Objetivo principal del paciente
  alergias           String? // Alergias a productos/sustancias
  condicionesMedicas String? // Condiciones médicas relevantes
  medicacionActual   String? // Medicamentos que toma actualmente
  embarazoLactancia  Boolean? @default(false)

  contactoEmergenciaNombre   String?
  contactoEmergenciaTelefono String?
  estado                     EstadoPaciente @default(ACTIVO)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  historiaClinica HistoriaClinica?
  citas           Cita[]
  cobros          Cobro[]
  tratamientos    Tratamiento[]
  protocolos      Protocolo[]
  documentos      Documento[]

  @@unique([documento, tipoDocumento])
  @@index([nombre, apellido])
  @@index([documento])
  @@index([estado])
  @@map("pacientes")
}

enum TipoDocumentoIdentidad {
  DNI
  PASAPORTE // Extranjero
}

enum EstadoPaciente {
  ACTIVO
  INACTIVO
}

// ========================================
// MÓDULO: HISTORIA CLÍNICA ESTÉTICA
// ========================================

model HistoriaClinica {
  id         String @id @default(uuid())
  pacienteId String @unique

  // Datos generales de salud
  tipoSangre         String?
  condicionesMedicas String? // Enfermedades, alergias relevantes
  medicacionHabitual String?
  cirugiasEsteticas  String? // Procedimientos estéticos previos
  cirugiasGenerales  String? // Cirugías generales previas

  // Historial estético
  tratamientosPrevios String? // Tratamientos estéticos anteriores
  productosCosmeticos String? // Rutina de cuidado actual
  exposicionSolar     String? // Hábitos de exposición solar
  habitosVida         String? // Alcohol, tabaco, ejercicio, dieta

  // Evaluación inicial
  tipoPiel              String? // Grasa, seca, mixta, sensible
  fototipoFitzpatrick   String? // I-VI escala Fitzpatrick
  preocupacionPrincipal String? // Arrugas, manchas, acné, etc.

  notasGenerales String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  paciente     Paciente      @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  tratamientos Tratamiento[]

  @@index([pacienteId])
  @@map("historias_clinicas")
}

// ========================================
// MÓDULO: TRATAMIENTOS ESTÉTICOS
// ========================================

model Tratamiento {
  id                String   @id @default(uuid())
  pacienteId        String
  historiaClinicaId String
  usuarioId         String
  citaId            String?
  fecha             DateTime @default(now())

  // Información del tratamiento
  tipoTratamiento   TipoTratamiento // Facial, Corporal, Capilar
  nombreTratamiento String // Nombre específico del procedimiento
  zonaTratada       String // Área específica del cuerpo
  objetivo          String // Objetivo del tratamiento

  // Evaluación y protocolo
  evaluacionInicial String? // Estado inicial de la piel/área
  protocolo         String? // Protocolo aplicado
  observaciones     String?
  proximaSesion     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  historiaClinica HistoriaClinica @relation(fields: [historiaClinicaId], references: [id], onDelete: Cascade)
  paciente        Paciente        @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  usuario         Usuario         @relation(fields: [usuarioId], references: [id])
  cita            Cita?           @relation(fields: [citaId], references: [id])
  protocolos      Protocolo[]
  cobros          Cobro[]

  @@index([pacienteId])
  @@index([historiaClinicaId])
  @@index([fecha])
  @@index([citaId])
  @@index([tipoTratamiento])
  @@map("tratamientos")
}

enum TipoTratamiento {
  FACIAL
  CORPORAL
  CAPILAR
  COMBINADO
}

// ========================================
// MÓDULO: CITAS Y AGENDA
// ========================================

model Cita {
  id                  String           @id @default(uuid())
  pacienteId          String
  fecha               DateTime
  horaInicio          String
  horaFin             String
  tipoTratamiento     TipoTratamiento? // Facial, Corporal, Capilar
  motivo              String
  estado              EstadoCita       @default(PROGRAMADA)
  notas               String?
  recordatorioEnviado Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  paciente     Paciente      @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  tratamientos Tratamiento[]

  @@index([pacienteId])
  @@index([fecha])
  @@index([estado])
  @@map("citas")
}

enum EstadoCita {
  PROGRAMADA
  CONFIRMADA
  EN_CURSO
  COMPLETADA
  CANCELADA
  NO_ASISTIO
}

// ========================================
// MÓDULO: SERVICIOS Y PRODUCTOS ESTÉTICOS
// ========================================

model Servicio {
  id          String             @id @default(uuid())
  codigo      String             @unique
  nombre      String
  categoria   CategoriaServicio? // Facial, Corporal, Capilar
  descripcion String?
  duracion    Int? // Duración estimada en minutos
  precio      Decimal            @db.Decimal(10, 2)
  activo      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  itemsCobro  ItemCobro[]

  @@index([codigo])
  @@index([activo])
  @@index([categoria])
  @@map("servicios")
}

enum CategoriaServicio {
  FACIAL
  CORPORAL
  CAPILAR
  PAQUETE
  CONSULTA
}

model Producto {
  id              String          @id @default(uuid())
  codigo          String          @unique
  nombre          String
  tipo            TipoProducto
  categoria       String? // Ej: Sérum, Crema, Ampolla, etc.
  descripcion     String?
  marca           String? // Marca comercial del producto
  principioActivo String? // Ingrediente activo principal
  precio          Decimal         @db.Decimal(10, 2)
  stock           Int             @default(0)
  stockMinimo     Int             @default(10)
  activo          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  itemsCobro      ItemCobro[]
  itemsProtocolo  ItemProtocolo[]

  @@index([codigo])
  @@index([activo])
  @@index([tipo])
  @@map("productos")
}

enum TipoProducto {
  COSMECEUTICO // Productos de uso profesional
  DERMOCOSMETICO // Productos de venta al paciente
  EQUIPO // Equipos/dispositivos
  INSUMO // Material fungible
}

// ========================================
// MÓDULO: COBROS Y FACTURACIÓN
// ========================================

model Cobro {
  id         String      @id @default(uuid())
  pacienteId String
  fecha      DateTime    @default(now())
  subtotal   Decimal     @default(0) @db.Decimal(10, 2)
  total      Decimal     @default(0) @db.Decimal(10, 2)
  estado     EstadoCobro @default(PENDIENTE)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  paciente      Paciente     @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  items         ItemCobro[]
  pagos         Pago[]
  tratamiento   Tratamiento? @relation(fields: [tratamientoId], references: [id])
  tratamientoId String?

  @@index([pacienteId])
  @@index([estado])
  @@index([fecha])
  @@map("cobros")
}

model ItemCobro {
  id             String        @id @default(uuid())
  cobroId        String
  tipo           TipoItemCobro
  servicioId     String?
  productoId     String?
  nombre         String
  cantidad       Int
  precioUnitario Decimal       @db.Decimal(10, 2)
  subtotal       Decimal       @db.Decimal(10, 2)
  createdAt      DateTime      @default(now())

  cobro    Cobro     @relation(fields: [cobroId], references: [id], onDelete: Cascade)
  servicio Servicio? @relation(fields: [servicioId], references: [id])
  producto Producto? @relation(fields: [productoId], references: [id])

  @@index([cobroId])
  @@index([servicioId])
  @@index([productoId])
  @@map("items_cobro")
}

enum TipoItemCobro {
  SERVICIO
  PRODUCTO
  PAQUETE
}

enum EstadoCobro {
  PENDIENTE
  PARCIAL
  PAGADO
  CANCELADO
}

model Pago {
  id         String     @id @default(uuid())
  cobroId    String
  fecha      DateTime   @default(now())
  monto      Decimal    @db.Decimal(10, 2)
  metodoPago MetodoPago
  referencia String?
  notas      String?
  createdAt  DateTime   @default(now())

  cobro Cobro @relation(fields: [cobroId], references: [id], onDelete: Cascade)

  @@index([cobroId])
  @@index([fecha])
  @@map("pagos")
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  OTRO
}

// ========================================
// MÓDULO: PROTOCOLOS DE CUIDADO EN CASA
// ========================================

model Protocolo {
  id         String   @id @default(uuid())
  pacienteId String
  usuarioId  String
  fecha      DateTime @default(now())
  nombre     String // Ej: "Protocolo post-peeling", "Rutina facial diaria"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paciente      Paciente        @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  usuario       Usuario         @relation(fields: [usuarioId], references: [id])
  items         ItemProtocolo[]
  tratamiento   Tratamiento?    @relation(fields: [tratamientoId], references: [id])
  tratamientoId String?

  @@index([pacienteId])
  @@index([fecha])
  @@map("protocolos")
}

model ItemProtocolo {
  id          String              @id @default(uuid())
  protocoloId String
  tipo        TipoItemProtocolo
  itemId      String
  nombre      String
  cantidad    Int
  aplicacion  String? // Ej: "Aplicar por la noche", "Mañana y noche"
  frecuencia  String?
  duracion    String?
  estado      EstadoItemProtocolo @default(INDICADO)
  precio      Decimal?            @db.Decimal(10, 2)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  protocolo  Protocolo @relation(fields: [protocoloId], references: [id], onDelete: Cascade)
  productoId String?
  producto   Producto? @relation(fields: [productoId], references: [id])

  @@index([protocoloId])
  @@index([estado])
  @@map("items_protocolo")
}

enum TipoItemProtocolo {
  PRODUCTO
  RECOMENDACION // Ej: "Usar bloqueador solar"
}

enum EstadoItemProtocolo {
  INDICADO
  ADQUIRIDO
  EN_USO
  COMPLETADO
}

// ========================================
// MÓDULO: DOCUMENTOS Y SEGUIMIENTO FOTOGRÁFICO
// ========================================

model Documento {
  id         String        @id @default(uuid())
  pacienteId String
  nombre     String
  tipo       TipoDocumento
  url        String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  paciente Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([pacienteId])
  @@index([tipo])
  @@map("documentos")
}

enum TipoDocumento {
  FOTO
  DOCUMENTO
}
